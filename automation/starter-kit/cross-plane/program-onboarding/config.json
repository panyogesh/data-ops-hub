{
  "helm": {
    "cross_plane": {
      "chart": "crossplane",
      "reponame": "crossplane-stable",
      "repourl": "https://charts.crossplane.io/stable",
      "version": "1.11.0",
      "namespace": "crossplane-system",
      "context": "kind-crossplane-dev"
    }
  },
  "kubeconfig": {
    "context": "kind-crossplane-dev",
    "namespace": "crossplane-system"
  },
  "providers": [
    {
      "name": "provider-gcp",
      "package": "xpkg.upbound.io/upbound/provider-gcp-compute:v1.8.1",
      "source": "crossplane/provider-gcp:v0.25.0"
    }
  ],
  "yamlPaths": {
    "provider": "pkg/crossplane/config-yamls/gcp/00-provider.yaml",
    "secret": "pkg/crossplane/config-yamls/gcp/01-gcp-secret.yaml",
    "providerConfig": "pkg/crossplane/config-yamls/gcp/02-providerconfig.yaml"
  },
  "gcp": {
    "project_id": "crossplane-dev",
    "region": "us-central1",
    "zone": "us-central1-a",
    "secret_name": "crossplane-dev-secret"
  }
}
